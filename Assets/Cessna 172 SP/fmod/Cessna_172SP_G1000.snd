1000
ACF_SOUNDS

##########################################
# Cessna 172 SP Skyhawk sound bank       #
# 2.0.0                                  #
# Michael Klier                          #
# Daniela Rodriguez Careri               #
# Laminar Research                       #
##########################################

DISABLE_LEGACY_ALERT_SOUNDS

# ATTENTION: This is a generated file, do not hand edit. 
#############################################################################################

# Spaces 
#############################################################################################
BEGIN_SOUND_SPACE
	SOUND_INDEX 0
	BLEND_DEPTH 0.03
	AABB -0.550 -0.650 -0.779 0.550 0.670 1.821
END_SOUND_SPACE

# Snapshots 
#############################################################################################

# -------------------- Mute sounds during initialization ---------------------
BEGIN_SOUND_ATTACHMENT
	SNAPSHOT_NAME /ducker
	EVENT_START_COND sim/time/total_flight_time_sec > 0
	EVENT_END_COND sim/time/total_flight_time_sec > 5
END_SOUND_ATTACHMENT
BEGIN_SOUND_ATTACHMENT
	SNAPSHOT_NAME /in_cockpit_door_left_open
	VEH_XYZ -0.700 0.042 0.659
	PARAM_DREF_IDX 0
	EVENT_START_COND sim/flightmodel2/misc/door_open_ratio[0] > 0
	EVENT_AUTO_END_FROM_START_COND
END_SOUND_ATTACHMENT
BEGIN_SOUND_ATTACHMENT
	SNAPSHOT_NAME /in_cockpit_door_right_open
	VEH_XYZ 0.700 0.042 0.659
	PARAM_DREF_IDX 1
	EVENT_START_COND sim/flightmodel2/misc/door_open_ratio[1] > 0
	EVENT_AUTO_END_FROM_START_COND
END_SOUND_ATTACHMENT
BEGIN_SOUND_ATTACHMENT
	SNAPSHOT_NAME /in_cockpit
	PARAM_DREF_IDX 0
	EVENT_START_COND sim/operation/sound/inside_ratio[0] != 0
	EVENT_AUTO_END_FROM_START_COND
END_SOUND_ATTACHMENT

# Engine 
#############################################################################################

# -------------------- Engine ---------------------
BEGIN_SOUND_ATTACHMENT
	EVENT_NAME /c172/engines/engine
	VEH_PART engine 0
	EVENT_ALLOWED_FOR_AI
	PARAM_DREF_IDX 0
	EVENT_START_COND sim/flightmodel2/misc/has_crashed == 0
	EVENT_START_COND sim/operation/failures/rel_engsep0 != 6
	EVENT_START_COND sim/flightmodel2/engines/engine_rotation_speed_rad_sec[0] > 1
	EVENT_AUTO_END_FROM_START_COND
END_SOUND_ATTACHMENT

# -------------------- Starter ---------------------
BEGIN_SOUND_ATTACHMENT
	EVENT_NAME /c172/engines/starter
	VEH_PART engine 0
	EVENT_ALLOWED_FOR_AI
	PARAM_DREF_IDX 0
	EVENT_ALWAYS
END_SOUND_ATTACHMENT

# -------------------- Engine fire ---------------------
BEGIN_SOUND_ATTACHMENT
	EVENT_NAME /c172/engines/engine_fire
	VEH_PART engine 0
	PARAM_DREF_IDX 0
	EVENT_START_COND sim/operation/failures/rel_engfir0 == 6
	EVENT_END_COND sim/operation/failures/rel_engfir0 != 6
END_SOUND_ATTACHMENT

# -------------------- Engine sep ---------------------
BEGIN_SOUND_ATTACHMENT
	EVENT_NAME /c172/engines/engine_sep
	VEH_PART engine 0
	PARAM_DREF_IDX 0
	EVENT_START_COND sim/operation/failures/rel_engsep0 == 6
	EVENT_END_COND sim/operation/failures/rel_engsep0 != 6
END_SOUND_ATTACHMENT

# Cockpit 
#############################################################################################

# -------------------- Avionics ---------------------
BEGIN_SOUND_ATTACHMENT
	EVENT_NAME /c172/equipment/avionics
	VEH_XYZ 0.101 0.099 -0.574
	EVENT_START_COND sim/cockpit2/switches/avionics_power_on == 1
	EVENT_START_COND sim/cockpit2/electrical/battery_on[0] == 1
	EVENT_AUTO_END_FROM_START_COND
END_SOUND_ATTACHMENT

# -------------------- Bobblehead ---------------------
BEGIN_SOUND_ATTACHMENT
	EVENT_NAME /c172/equipment/bobblehead_on
	VEH_XYZ -0.085 0.347 -0.425
	EVENT_START_COND DELTA=sim/cockpit2/switches/custom_slider_on[19] > 0
	EVENT_END_COND sim/cockpit2/switches/custom_slider_on[19] == 0
END_SOUND_ATTACHMENT
BEGIN_SOUND_ATTACHMENT
	EVENT_NAME /c172/equipment/bobblehead_off
	VEH_XYZ 0.402 -0.097 -0.491
	EVENT_START_COND DELTA=sim/cockpit2/switches/custom_slider_on[19] < 0
	EVENT_END_COND sim/cockpit2/switches/custom_slider_on[19] == 1
END_SOUND_ATTACHMENT

# -------------------- Glovebox ---------------------
BEGIN_SOUND_ATTACHMENT
	EVENT_NAME /c172/equipment/glovebox_open
	VEH_XYZ 0.402 -0.097 -0.491
	PARAM_DREF_IDX 23
	EVENT_START_COND DELTA=sim/flightmodel2/misc/custom_slider_ratio[23] > 0.1
	EVENT_END_COND DELTA=sim/flightmodel2/misc/custom_slider_ratio[23] <= 0
END_SOUND_ATTACHMENT
BEGIN_SOUND_ATTACHMENT
	EVENT_NAME /c172/equipment/glovebox_close
	VEH_XYZ 0.402 -0.097 -0.491
	PARAM_DREF_IDX 23
	EVENT_START_COND DELTA=sim/flightmodel2/misc/custom_slider_ratio[23] < -0.1
	EVENT_END_COND DELTA=sim/flightmodel2/misc/custom_slider_ratio[23] >= 0
END_SOUND_ATTACHMENT

# -------------------- Gyro ---------------------
BEGIN_SOUND_ATTACHMENT
	EVENT_NAME /c172/equipment/gyro
	VEH_XYZ -0.090 0.076 -0.621
	PARAM_DREF_IDX 0
	EVENT_START_COND sim/cockpit/gyros/gyr_spin[0] > 0
	EVENT_AUTO_END_FROM_START_COND
END_SOUND_ATTACHMENT

# Equipment 
#############################################################################################

# -------------------- Fuel pump ---------------------
BEGIN_SOUND_ATTACHMENT
	EVENT_NAME /c172/equipment/fuel_pump
	VEH_XYZ 0.403 -0.421 -1.282
	EVENT_ALLOWED_FOR_AI
	EVENT_START_COND sim/flightmodel2/engines/fuel_pump_spinning[0] == 1
	EVENT_START_COND sim/cockpit2/electrical/battery_on[0] == 1
	EVENT_AUTO_END_FROM_START_COND
END_SOUND_ATTACHMENT

# -------------------- Flaps lower ---------------------
BEGIN_SOUND_ATTACHMENT
	EVENT_NAME /c172/equipment/flaps_lower
	VEH_XYZ 2.006 0.674 1.340
	PARAM_DREF_IDX 0
	EVENT_START_COND DELTA=sim/flightmodel2/wing/flap1_deg[0] > 0
	EVENT_END_COND DELTA=sim/flightmodel2/wing/flap1_deg[0] <= 0
END_SOUND_ATTACHMENT

# -------------------- Flaps raise ---------------------
BEGIN_SOUND_ATTACHMENT
	EVENT_NAME /c172/equipment/flaps_raise
	VEH_XYZ 2.006 0.674 1.340
	PARAM_DREF_IDX 0
	EVENT_START_COND DELTA=sim/flightmodel2/wing/flap1_deg[0] < 0
	EVENT_END_COND DELTA=sim/flightmodel2/wing/flap1_deg[0] >= 0
END_SOUND_ATTACHMENT

# -------------------- Wing strobe ---------------------
BEGIN_SOUND_ATTACHMENT
	EVENT_NAME /c172/equipment/wing_strobe
	VEH_XYZ -5.505 0.841 1.377
	EVENT_START_COND sim/flightmodel2/lights/strobe_flash_now == 1
END_SOUND_ATTACHMENT
BEGIN_SOUND_ATTACHMENT
	EVENT_NAME /c172/equipment/wing_strobe
	VEH_XYZ 5.505 0.841 1.377
	EVENT_START_COND sim/flightmodel2/lights/strobe_flash_now == 1
END_SOUND_ATTACHMENT

# -------------------- Door L ---------------------
BEGIN_SOUND_ATTACHMENT
	EVENT_NAME /c172/equipment/door_open
	VEH_XYZ -0.700 0.042 0.659
	PARAM_DREF_IDX 0
	EVENT_START_COND DELTA=sim/flightmodel2/misc/door_open_ratio[0] > 0
	EVENT_END_COND DELTA=sim/flightmodel2/misc/door_open_ratio[0] <= 0
END_SOUND_ATTACHMENT
BEGIN_SOUND_ATTACHMENT
	EVENT_NAME /c172/equipment/door_close
	VEH_XYZ -0.700 0.042 0.659
	PARAM_DREF_IDX 0
	EVENT_START_COND DELTA=sim/flightmodel2/misc/door_open_ratio[0] < 0
	EVENT_END_COND DELTA=sim/flightmodel2/misc/door_open_ratio[0] >= 0
END_SOUND_ATTACHMENT

# -------------------- Door R ---------------------
BEGIN_SOUND_ATTACHMENT
	EVENT_NAME /c172/equipment/door_open
	VEH_XYZ 0.700 0.042 0.659
	PARAM_DREF_IDX 1
	EVENT_START_COND DELTA=sim/flightmodel2/misc/door_open_ratio[1] > 0
	EVENT_END_COND DELTA=sim/flightmodel2/misc/door_open_ratio[1] <= 0
END_SOUND_ATTACHMENT
