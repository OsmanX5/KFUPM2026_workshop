	EVENT_NAME /c172/environment/rain_int
	VEH_PART cockpit 0
	PARAM_DREF_IDX 0
	EVENT_START_COND sim/weather/precipitation_on_aircraft_ratio != 0
	EVENT_END_COND sim/weather/precipitation_on_aircraft_ratio == 0
END_SOUND_ATTACHMENT

# -------------------- Rain ext ---------------------
BEGIN_SOUND_ATTACHMENT
	EVENT_NAME /c172/environment/rain_ext
	VEH_XYZ 0.000 0.000 0.121
	EVENT_START_COND sim/weather/precipitation_on_aircraft_ratio != 0
	EVENT_END_COND sim/weather/precipitation_on_aircraft_ratio == 0
END_SOUND_ATTACHMENT

# -------------------- Turbulence ---------------------
BEGIN_SOUND_ATTACHMENT
	EVENT_NAME /c172/environment/turbulence
	VEH_PART cockpit 0
	EVENT_POLYPHONIC
	PARAM_DREF_IDX 0
	EVENT_START_COND ABS_DELTA=sim/flightmodel/forces/g_nrml > 0.90
END_SOUND_ATTACHMENT

